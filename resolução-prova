  <!-- ================================================================
       QUESTÃO 04 – DOM / PLAYER CARDS
  ================================================================ -->
  <section id="q4" class="page-section">

    <div id="q4-header">
      <h2 class="section-title">
        <span class="q-badge">Q4</span>
        Manipulação DOM – Adicionar Jogador
      </h2>
      <p class="section-subtitle">
        Clique no botão para inserir um novo card de jogador ao lado do card existente, sem remover o anterior.
      </p>
    </div>

    <!-- BOTÃO ADICIONAR -->
    <div class="btn-add-player">
      <button onclick="add()">➕ Adcionar Novo Jogador</button>
    </div>

    <!-- PLAYER CARDS CONTAINER -->
    <div class="players-wrapper" id="players-container">

      <!-- CARD ORIGINAL -->
      <div class="player-card" id="card-original">
        <div class="player-card-header">
          <div class="avatar">🧑</div>
          <h4 id="nome-original">Neymar Jr.</h4>
          <span class="position-badge" id="posicao-original">Atacante</span>
        </div>
        <div class="player-card-body">
          <div class="player-info-row">
            <span class="label">📅 Nascimento</span>
            <span class="value" id="nasc-original">05/02/1992</span>
          </div>
          <div class="player-info-row">
            <span class="label">📏 Altura</span>
            <span class="value" id="alt-original">1,75 m</span>
          </div>
          <div class="player-info-row">
            <span class="label">🏃 Posição</span>
            <span class="value" id="pos-original">Atacante</span>
          </div>
          <div class="player-info-row">
            <span class="label">⭐ Rank</span>
            <span class="value rank-stars" id="rank-original">★★★★★ 9.5</span>
          </div>
        </div>
      </div>

    </div><!-- /players-container -->

    <div class="info-box" style="margin-top:28px;">
      <h5>📝 Nota Técnica (Q4)</h5>
      A função <code>add()</code> é disparada pelo evento <code>onclick</code> do botão.
      Ela cria um novo elemento <code>div.player-card</code> com a estrutura completa do perfil de Lucas Paquetá
      e o insere via <code>appendChild()</code> no container, sem alterar o card original.
      O card novo recebe a classe <code>new-card</code> para a animação de entrada.
    </div>

  </section>

  <!-- ===== FOOTER ===== -->
  <footer>
    <p>© 2026 – DFMF System &nbsp;|&nbsp; Avaliação FrontEnd</p>
  </footer>

  <!-- ================================================================
       JAVASCRIPT
  ================================================================ -->
  <script>
    /* =====================================================
       NAVEGAÇÃO POR ABAS
    ===================================================== */
    function showSection(id) {
      document.querySelectorAll('.page-section').forEach(s => s.classList.remove('active'));
      document.querySelectorAll('nav.tabs button').forEach(b => b.classList.remove('active'));

      document.getElementById(id).classList.add('active');

      const btnIndex = { q1: 0, q2: 1, q3: 2, q4: 3 };
      document.querySelectorAll('nav.tabs button')[btnIndex[id]].classList.add('active');

      // inicializa Q3 ao abrir
      if (id === 'q3' && !q3Initialized) {
        renderQ3();
        q3Initialized = true;
      }
    }

    /* =====================================================
       QUESTÃO 03 – DADOS E LÓGICA DO BOTÃO PRÓXIMO
    ===================================================== */
    let q3Page = 0;
    let q3Initialized = false;

    const paginaGrupos = [
      // Página 1 – Grupos A, B, C
      [
        {
          id: 'grupo-a',
          emoji: '🅰️',
          nome: 'Grupo A',
          selecoes: ['México', 'África do Sul', 'Coreia do Sul', 'República Tcheca'],
          fatos: 'O jogo de abertura será México x África do Sul. Confrontos entre Coreia do Sul e seleções europeias já ocorreram em várias Copas, com histórico equilibrado.'
        },
        {
          id: 'grupo-b',
          emoji: '🅱️',
          nome: 'Grupo B',
          selecoes: ['Canadá', 'Suíça', 'Catar', 'Vaga Europeia (Bósnia)'],
          fatos: 'O Canadá joga em casa, fator importante de desempenho. Catar e Suíça já se enfrentaram recentemente em amistosos internacionais.'
        },
        {
          id: 'grupo-c',
          emoji: '🅲',
          nome: 'Grupo C',
          selecoes: ['Brasil', 'Marrocos', 'Haiti', 'Escócia'],
          fatos: 'Brasil, Marrocos e Escócia já dividiram grupo em 1998. Brasil nunca perdeu para a Escócia em Copas.'
        }
      ],
      // Página 2 – Grupos D, E, F
      [
        {
          id: 'grupo-d',
          emoji: '🅳',
          nome: 'Grupo D',
          selecoes: ['Estados Unidos', 'Paraguai', 'Austrália', 'Turquia'],
          fatos: 'Os EUA jogam em casa, vantagem histórica em Copas. Austrália enfrenta frequentemente seleções sul-americanas em torneios.'
        },
        {
          id: 'grupo-e',
          emoji: '🅴',
          nome: 'Grupo E',
          selecoes: ['Alemanha', 'Equador', 'Costa do Marfim', 'Curaçao'],
          fatos: 'Alemanha costuma dominar fases de grupos. Equador e Costa do Marfim têm estilos físicos semelhantes.'
        },
        {
          id: 'grupo-f',
          emoji: '🅵',
          nome: 'Grupo F',
          selecoes: ['Holanda', 'Japão', 'Tunísia', 'Suécia'],
          fatos: 'Brasil, Marrocos e Escócia já dividiram grupo em 1998. Brasil nunca perdeu para a Escócia em Copas.'
        }
      ]
    ];

    function renderQ3() {
      const container = document.getElementById('q3-grupos');
      const grupos = paginaGrupos[q3Page];
      container.innerHTML = '';

      grupos.forEach(g => {
        const liItems = g.selecoes.map(s => `<li>${s}</li>`).join('');
        const card = document.createElement('div');
        card.id = g.id;
        card.className = 'group-card';
        card.innerHTML = `
          <h2>${g.emoji} ${g.nome}</h2>
          <h3>Seleções</h3>
          <ul>${liItems}</ul>
          <details>
            <summary>📖 Saiba Mais</summary>
            <p>${g.fatos}</p>
          </details>
        `;
        container.appendChild(card);
      });

      // Atualiza indicador e botão
      const indicator = document.getElementById('page-indicator');
      const btnLabel  = document.getElementById('btn-label');

      if (q3Page === 0) {
        indicator.textContent = '📋 Exibindo: Página 1 de 2 — Grupos A, B e C';
        btnLabel.textContent  = 'Próximo ▶';
      } else {
        indicator.textContent = '📋 Exibindo: Página 2 de 2 — Grupos D, E e F';
        btnLabel.textContent  = '◀ Anterior';
      }
    }

    function proximoGrupo() {
      q3Page = q3Page === 0 ? 1 : 0;
      renderQ3();
    }

    /* =====================================================
       QUESTÃO 04 – FUNÇÃO add() – ADICIONAR JOGADOR
    ===================================================== */
    let playerAdded = false;

    function add() {
      const container = document.getElementById('players-container');

      if (playerAdded) {
        alert('⚠️ O jogador Lucas Paquetá já foi adicionado!');
        return;
      }

      // Cria o novo card
      const card = document.createElement('div');
      card.className = 'player-card new-card';
      card.id = 'card-paqueta';

      card.innerHTML = `
        <div class="player-card-header">
          <div class="avatar">
            <img src="img/Lucas_Paqueta.png" alt="Lucas Paquetá"
              onerror="this.parentElement.innerHTML='⚽';" />
          </div>
          <h4 id="nome-paqueta">Lucas Tolentino Coelho de Lima</h4>
          <span class="position-badge" id="posicao-paqueta">Meio-campista</span>
        </div>
        <div class="player-card-body">
          <div class="player-info-row">
            <span class="label">📅 Nascimento</span>
            <span class="value" id="nasc-paqueta">27/08/1997 (28 anos)</span>
          </div>
          <div class="player-info-row">
            <span class="label">📏 Altura</span>
            <span class="value" id="alt-paqueta">1,80 m</span>
          </div>
          <div class="player-info-row">
            <span class="label">🏃 Posição</span>
            <span class="value" id="pos-paqueta">Meio-campista</span>
          </div>
          <div class="player-info-row">
            <span class="label">⭐ Rank</span>
            <span class="value rank-stars" id="rank-paqueta">★★★★☆ 8.8</span>
          </div>
        </div>
      `;

      container.appendChild(card);
      playerAdded = true;

      // Feedback no botão
      const btn = document.querySelector('.btn-add-player button');
      btn.textContent = '✅ Jogador Adicionado!';
      btn.style.background = 'linear-gradient(135deg, #2c5282, #2b6cb0)';
      btn.disabled = true;
      btn.style.cursor = 'not-allowed';
    }
  </script>

</body>
</html>
